# DEALSCANNR — copy to `.env` at repo root and/or `packages/api/.env` (package wins if both set).

# --- Core services ---
# Local Docker: mongodb://localhost:5300/dealscannr
# Atlas (quote the URL if the password has ! # @ etc.):
# DATABASE_URL="mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/dealscannr?retryWrites=true&w=majority"
DATABASE_URL=mongodb://localhost:5300/dealscannr
# Local: redis://localhost:5400  |  Upstash (TLS): rediss://default:TOKEN@xxxx.upstash.io:6379
REDIS_URL=redis://localhost:5400
QDRANT_URL=http://localhost:5500
# Qdrant Cloud: set the read/write API key from the cluster dashboard (optional for local Docker).
QDRANT_API_KEY=

# --- API security & URLs ---
JWT_SECRET=change-me-min-32-characters-long-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=168
# CORS (JSON array in real env often set without quotes in pydantic — use comma list in .env as needed)
# CORS_ORIGINS=["http://localhost:5100"]
PUBLIC_APP_URL=http://localhost:5100
# Production: include your deployed web origin and API URL, e.g.
# CORS_ORIGINS=["https://your-app.onrender.com","https://dealscannr.onrender.com"]
# Frontend: VITE_API_URL=https://dealscannr.onrender.com

# --- LLM & embeddings (at least GROQ + one embedding provider for scans) ---
GROQ_API_KEY=
OPENAI_API_KEY=
# openai = OpenAI chat first when OPENAI_API_KEY is set; groq = Groq only
LLM_PROVIDER=openai
TOGETHER_API_KEY=
# TOGETHER_EMBEDDING_MODEL=
# TOGETHER_EMBEDDING_DIM=
NOMIC_API_KEY=
# GROQ_EMBEDDING_MODEL=

# --- Optional enrichment ---
FIRECRAWL_API_KEY=
GITHUB_TOKEN=
COURTLISTENER_API_KEY=
NEWSAPI_KEY=
# Adzuna job search (optional, free tier ~1000 calls/mo): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=
# ISO country code for Adzuna job API path (default us)
ADZUNA_COUNTRY=us

# --- Internal diagnostics (API) ---
# When set, GET /api/scans/{scan_id}/debug with header X-DealScannr-Debug-Secret: <same value>
SCAN_DEBUG_SECRET=

# --- Stripe billing (API) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# --- Email (Resend) — watchlist digest & batch summaries ---
RESEND_API_KEY=re_...

# --- Web (Vite) ---
VITE_API_URL=http://localhost:5200
